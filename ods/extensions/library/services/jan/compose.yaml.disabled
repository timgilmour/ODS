services:
  jan:
    image: ghcr.io/janhq/jan-server:v0.7.7
    container_name: ods-jan
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    environment:
      - LLM_API_URL=http://localhost:${JAN_PORT:-1337}
    volumes:
      - ./data/jan:/app/server/jan:rw
    ports:
      - "127.0.0.1:${JAN_PORT:-1337}:1337"
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://127.0.0.1:1337/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    networks:
      - ods-network
    deploy:
      resources:
        limits:
          cpus: '2.0'
          memory: 4G
        reservations:
          cpus: '0.5'
          memory: 1G

networks:
  ods-network:
    external: true
    name: ods-network
